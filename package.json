  "author": "Arthur Endlein Correia",
  "repository": { "type": "git", "url": "https://github.com/gentropic/webmcp.git" },
  "type": "commonjs",
  "bin": { "webmcp-bridge": "webmcp-bridge.js" },
  "files": ["webmcp-bridge.js", "shim.js", "SPEC.md", "README.md"],
  "scripts": {
    "info": "node webmcp-bridge.js --info",
    "smoke": "node tools/smoke.mjs",
    "e2e": "node tools/e2e-browser.mjs"
